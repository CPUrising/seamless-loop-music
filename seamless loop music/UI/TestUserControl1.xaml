<UserControl x:Class="seamless_loop_music.UI.TestUserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="400"
             Background="#1E1E1E">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="#FFFFFF"/>
    </UserControl.Resources>

    <Grid d:DataContext="{Binding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" 
                        Style="{StaticResource Marquee}" 
                        Content="超长音乐分类名称·古风重工业摇滚连续无缝循环交响乐"
                        FontSize="28"
                        Foreground="White"
                        FontWeight="Bold"
                        Height="45"
                        VerticalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="【标准参照组】Size 28：" Foreground="DimGray" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="古风重工业摇滚"
                       Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>