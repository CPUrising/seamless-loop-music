<UserControl x:Class="seamless_loop_music.UI.Views.TrackListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:controls="clr-namespace:seamless_loop_music.UI.Controls"
             xmlns:converters="clr-namespace:seamless_loop_music.UI.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <!-- BindingProxy：让 ContextMenu 等游离元素能访问 ViewModel -->
        <converters:BindingProxy x:Key="VmProxy" Data="{Binding}"/>

        <!-- 播放按钮样式 (复用 IconButton) -->
        <Style x:Key="TrackPlayButton" TargetType="Button" BasedOn="{StaticResource GhostIconButton}">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <!-- 精简版模板：仅保留播放按钮和标题/文件名 -->
        <DataTemplate x:Key="CompactTrackTemplate">
            <Grid Height="55" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Style="{StaticResource TrackPlayButton}"
                        Content="{StaticResource IconPlay}"
                        Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FileName}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- 完整版模板 -->
        <DataTemplate x:Key="FullTrackTemplate">
            <Grid Height="55" Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/> <!-- Play -->
                    <ColumnDefinition Width="35"/> <!-- Love -->
                    <ColumnDefinition Width="2*"/> <!-- Title -->
                    <ColumnDefinition Width="1*"/> <!-- Artist -->
                    <ColumnDefinition Width="1*"/> <!-- Album -->
                    <ColumnDefinition Width="Auto"/> <!-- Rating -->
                    <ColumnDefinition Width="Auto"/> <!-- Action -->
                </Grid.ColumnDefinitions>

                <!-- Play Button -->
                <Button Grid.Column="0" 
                        Style="{StaticResource TrackPlayButton}"
                        Content="{StaticResource IconPlay}"
                        Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"/>

                <!-- Love Button -->
                <Button Grid.Column="1" 
                        Command="{Binding DataContext.ToggleLoveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{StaticResource IconLove}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoved}" Value="True">
                                        <Setter Property="Text" Value="{StaticResource IconLoved}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Title & Filename -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FileName}" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Artist -->
                <TextBlock Grid.Column="3" Text="{Binding Artist}" VerticalAlignment="Center" Foreground="{StaticResource BrushTextPrimary}" FontSize="14" TextTrimming="CharacterEllipsis" Margin="8,0"/>

                <!-- Album -->
                <TextBlock Grid.Column="4" Text="{Binding Album}" VerticalAlignment="Center" Foreground="{StaticResource BrushTextPrimary}" FontSize="14" TextTrimming="CharacterEllipsis" Margin="8,0" Opacity="0.8"/>

                <!-- Rating -->
                <Button Grid.Column="5" Command="{Binding DataContext.RateCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"
                        Background="Transparent" BorderThickness="0" Margin="8,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{StaticResource IconStar}" Foreground="{StaticResource BrushWarning}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Rating}" Foreground="{StaticResource BrushWarning}" FontSize="14" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Action Buttons: Analyze & Edit -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Style="{StaticResource IconButton}"
                            Content="{StaticResource IconAnalyze}"
                            Command="{Binding DataContext.AnalyzeTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}"
                            ToolTip="{Binding [TipFindLoop], Source={StaticResource Loc}}"
                            Margin="0,0,8,0"/>

                    <Button Style="{StaticResource IconButton}"
                            Content="{StaticResource IconEdit}"
                            Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}"
                            ToolTip="{Binding [TipEditProperties], Source={StaticResource Loc}}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Search -->
            <RowDefinition Height="*"/>    <!-- List -->
        </Grid.RowDefinitions>

        <!-- Playlist Header & Stats -->
        <Border Grid.Row="0" Margin="20,20,20,10" Background="{StaticResource BrushSurface}" CornerRadius="12" Padding="25,20">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="70" Height="70" CornerRadius="10" Background="{StaticResource BrushSurfaceHighlight}" Margin="0,0,25,0">
                    <TextBlock Text="{StaticResource IconMusic}" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <Viewbox HorizontalAlignment="Left" MaxHeight="45" StretchDirection="DownOnly" MaxWidth="600">
                        <TextBlock Text="{Binding CategoryName}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </Viewbox>
                    <Grid Margin="0,8,0,0">
                        <TextBlock Text="{Binding PlaylistStats}" Foreground="{StaticResource BrushTextSecondary}" FontSize="15" 
                                   Visibility="{Binding IsAnalyzing, Converter={StaticResource NullToVisibilityInverseConverter}, ConverterParameter='Inverse'}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushAccent}" FontSize="15" FontWeight="Medium"
                                   Visibility="{Binding IsAnalyzing, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Margin="20,5,20,10" Background="{StaticResource BrushSurface}" CornerRadius="10" Height="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource IconSearch}" VerticalAlignment="Center" Margin="15,0,8,0" Foreground="{StaticResource BrushTextSecondary}" IsHitTestVisible="False" FontSize="14"/>
                <TextBox Grid.Column="1" x:Name="SearchTextBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" BorderThickness="0" 
                         Foreground="White" VerticalContentAlignment="Center"
                         FontSize="15" CaretBrush="{StaticResource BrushAccent}"
                         Margin="5,0,15,0"/>
                
                <TextBlock Grid.Column="1" Text="{Binding SearchPlaceholder}" 
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" 
                           Margin="8,0,0,0" IsHitTestVisible="False"
                           FontSize="15">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding SearchText}" Value=""/>
                                        <Condition Binding="{Binding ElementName=SearchTextBox, Path=IsKeyboardFocused}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding SearchText}" Value="{x:Null}"/>
                                        <Condition Binding="{Binding ElementName=SearchTextBox, Path=IsKeyboardFocused}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <controls:MultiSelectListBox x:Name="TrackList" Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="10,0,10,10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch"
                 ItemsSource="{Binding TracksView}"
                 SelectedItem="{Binding SelectedTrack}"
                 SelectedItemsBinding="{Binding SelectedTracks}"
                 SelectionMode="Extended"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 SelectionChanged="TrackList_SelectionChanged">
            <controls:MultiSelectListBox.InputBindings>
                <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding SelectAllCommand}"/>
                <KeyBinding Key="Delete" Command="{Binding RemoveFromListCommand}"/>
                <KeyBinding Key="Delete" Modifiers="Shift" Command="{Binding DeleteFromDiskCommand}"/>
            </controls:MultiSelectListBox.InputBindings>
            <controls:MultiSelectListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="ItemTemplate" Value="{StaticResource FullTrackTemplate}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                            <Setter Property="ItemTemplate" Value="{StaticResource CompactTrackTemplate}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:MultiSelectListBox.Style>
            <controls:MultiSelectListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <!-- 通过 VmProxy 访问 ViewModel，PlacementTarget.DataContext 获取当前行 MusicTrack -->
                            <ContextMenu Background="{StaticResource BrushSurface}" BorderThickness="0" Padding="4" Foreground="{StaticResource BrushTextPrimary}">
                                <MenuItem Header="{Binding [MenuPlay], Source={StaticResource Loc}}"
                                          Command="{Binding Data.PlayCommand, Source={StaticResource VmProxy}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{Binding [MenuPlaySelected], Source={StaticResource Loc}}"
                                          Command="{Binding Data.PlaySelectedCommand, Source={StaticResource VmProxy}}"/>
                                <MenuItem Header="{Binding [MenuAnalyze], Source={StaticResource Loc}}"
                                          Command="{Binding Data.BatchAnalyzeCommand, Source={StaticResource VmProxy}}"/>
                                <Separator Background="{StaticResource BrushSeparator}" Margin="4,2"/>
                                <MenuItem Header="{Binding [MenuShowExplorer], Source={StaticResource Loc}}"
                                          Command="{Binding Data.ShowInExplorerCommand, Source={StaticResource VmProxy}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{Binding [MenuAddToPlaylist], Source={StaticResource Loc}}"
                                          Command="{Binding Data.AddToPlaylistCommand, Source={StaticResource VmProxy}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator Background="{StaticResource BrushSeparator}" Margin="4,2"/>
                                <MenuItem Command="{Binding Data.ToggleLoveCommand, Source={StaticResource VmProxy}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding [MenuLove], Source={StaticResource Loc}}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsLoved, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                    <Setter Property="Header" Value="{Binding [MenuUnlove], Source={StaticResource Loc}}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <Separator Background="{StaticResource BrushSeparator}" Margin="4,2"/>
                                <MenuItem Header="{Binding [MenuRemove], Source={StaticResource Loc}}"
                                          Command="{Binding Data.RemoveFromListCommand, Source={StaticResource VmProxy}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="{Binding [MenuDelete], Source={StaticResource Loc}}"
                                          Foreground="{StaticResource BrushDanger}"
                                          Command="{Binding Data.DeleteFromDiskCommand, Source={StaticResource VmProxy}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushSelection}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:MultiSelectListBox.ItemContainerStyle>
        </controls:MultiSelectListBox>
    </Grid>
</UserControl>
