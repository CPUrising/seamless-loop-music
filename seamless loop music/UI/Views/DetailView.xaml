<UserControl x:Class="seamless_loop_music.UI.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="#1E1E2E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Lyrics / Album Cover -->
        <Border Grid.Column="0" Margin="20" Background="#313244" CornerRadius="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border CornerRadius="10" Background="#45475A" Width="250" Height="250" Margin="20">
                         <Path Data="M 12 1 Q 12 0 13 0 L 23 0 Q 24 0 24 1 L 24 23 Q 24 24 23 24 L 13 24 Q 12 24 12 23 Z" Fill="#89B4FA" Stretch="Uniform" Margin="50"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentTrack.DisplayName}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentTrack.FileName}" FontSize="14" HorizontalAlignment="Center" Foreground="#A6ADC8" Margin="0,5" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                
                <TextBlock Grid.Row="1" Text="L Y R I C S" Foreground="#585B70" HorizontalAlignment="Center" Margin="20" FontWeight="Black" Opacity="0.5"/>
            </Grid>
        </Border>

        <!-- Right: LoopWorkspace -->
        <Border Grid.Column="1" Margin="0,20,20,20" Background="#181825" CornerRadius="15">
            <local:LoopWorkspace/>
        </Border>
    </Grid>
</UserControl>
