<UserControl x:Class="seamless_loop_music.UI.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="DetailTopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"/>
            <ColumnDefinition Width="0.6*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Track List -->
        <Grid Grid.Column="0" Margin="15,20,10,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navigation Buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,10">
                <Button Content="{Binding [BtnBackToLibrary], Source={StaticResource Loc}}" 
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource DetailTopButtonStyle}"/>
                
                <Button Content="{Binding [BtnFullScreen], Source={StaticResource Loc}}" 
                        Command="{Binding GoToDetailCommand}"
                        Style="{StaticResource DetailTopButtonStyle}"
                        Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Track List Side Content -->
            <Border Grid.Row="1" Background="#181825" CornerRadius="15">
                <ContentControl prism:RegionManager.RegionName="DetailListRegion" />
            </Border>
        </Grid>

        <!-- Right: LoopWorkspace -->
        <Border Grid.Column="1" Margin="0,20,20,20" Background="#181825" CornerRadius="15">
            <local:LoopWorkspace/>
        </Border>
    </Grid>
</UserControl>
