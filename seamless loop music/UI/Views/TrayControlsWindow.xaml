<Window x:Class="seamless_loop_music.UI.Views.TrayControlsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayMenu" Height="270" Width="200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Colors.xaml" />
                <ResourceDictionary Source="../Themes/Controls.xaml" />
                <ResourceDictionary Source="../Themes/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="TrayMenuButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,0">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="buttonBorder" Property="Background" Value="{DynamicResource BrushOverlayHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="buttonBorder" Property="Background" Value="{DynamicResource BrushOverlayPressed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TrayModeRadio" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="radioBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="checkMark" Text="○" Foreground="{DynamicResource BrushTextSecondary}" FontSize="16" VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="radioBorder" Property="Background" Value="{DynamicResource BrushOverlayHover}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="checkMark" Property="Text" Value="●"/>
                                    <Setter TargetName="checkMark" Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TrayCheckToggle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="toggleBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="checkMark" Text="" Foreground="{DynamicResource BrushAccent}" FontSize="14" VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="toggleBorder" Property="Background" Value="{DynamicResource BrushOverlayHover}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="checkMark" Property="Text" Value="✓"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Border Background="{DynamicResource BrushBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="Black" Opacity="0.48"/>
            </Border.Effect>
            <StackPanel>
                <Button Style="{StaticResource TrayMenuButton}" Command="{Binding PlayCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⏯" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding PlayPauseText}" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource TrayMenuButton}" Command="{Binding PrevCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="←" Foreground="{DynamicResource BrushTextSecondary}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding PreviousText}" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource TrayMenuButton}" Command="{Binding NextCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="→" Foreground="{DynamicResource BrushTextSecondary}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding NextText}" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Border Height="1" Background="{DynamicResource BrushSeparator}" Opacity="0.55" Margin="0,6"/>

                <Button x:Name="LoopPlaybackButton" Style="{StaticResource TrayMenuButton}" Command="{Binding TogglePlayModeMenuCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="↻" Foreground="{DynamicResource BrushTextSecondary}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding PlayModeText}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text=">" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <ToggleButton Content="{Binding SeamlessLoopText}" IsChecked="{Binding IsSeamlessLoopEnabled}" Style="{StaticResource TrayCheckToggle}"/>

                <Border Height="1" Background="{DynamicResource BrushSeparator}" Opacity="0.55" Margin="0,6"/>

                <Button Style="{StaticResource TrayMenuButton}" Command="{Binding ExitCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="↩" Foreground="{DynamicResource BrushTextSecondary}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ExitText}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <Popup x:Name="PlayModePopup"
               IsOpen="{Binding IsPlayModeMenuOpen}"
               PlacementTarget="{Binding ElementName=LoopPlaybackButton}"
               Placement="Left"
               AllowsTransparency="True"
               HorizontalOffset="-14"
               VerticalOffset="-4">
            <Border Background="{DynamicResource BrushBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="10" MinWidth="130">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="Black" Opacity="0.48"/>
                </Border.Effect>
                <StackPanel>
                    <RadioButton Content="{Binding SingleLoopText}" IsChecked="{Binding IsSingleLoop}" Style="{StaticResource TrayModeRadio}"/>
                    <RadioButton Content="{Binding ListLoopText}" IsChecked="{Binding IsListLoop}" Style="{StaticResource TrayModeRadio}"/>
                    <RadioButton Content="{Binding ShuffleText}" IsChecked="{Binding IsShuffle}" Style="{StaticResource TrayModeRadio}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
