<Window x:Class="seamless_loop_music.UI.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="180" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" d:DesignHeight="180" d:DesignWidth="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Message}" Foreground="#CDD6F4" FontSize="14" Margin="0,0,0,10"/>
        
        <TextBox Grid.Row="1" x:Name="InputTextBox" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" 
                 Background="#313244" Foreground="White" BorderThickness="1" BorderBrush="#45475A"
                 Padding="5" VerticalContentAlignment="Center" FontSize="14"
                 KeyDown="InputTextBox_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="确定" Width="80" Height="30" Margin="0,0,10,0" IsDefault="True"
                    Click="OkButton_Click" Background="#89B4FA" Foreground="#11111B" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="取消" Width="80" Height="30" IsCancel="True"
                    Background="#45475A" Foreground="#CDD6F4" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
