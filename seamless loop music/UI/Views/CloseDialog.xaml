<Window x:Class="seamless_loop_music.UI.Views.CloseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Information"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Dialog_MouseLeftButtonDown"
        FontFamily="Microsoft YaHei, Segoe UI, sans-serif">

    <Window.Resources>
        <!-- 现代风格的关闭按钮 -->
        <Style x:Key="WindowCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FCE8E8"/>
                                <Setter Property="Foreground" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F2C8C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 现代卡片式选项按钮 -->
        <Style x:Key="ModernCardButton" TargetType="Button">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="12">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- 悬浮时显示品牌色边框和浅色背景 -->
                                <Setter Property="Background" Value="#F3F8FB"/>
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E6F2F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 自定义 CheckBox 样式，使其更清爽 -->
        <Style TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#555555"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" BorderBrush="#EAEAEA" BorderThickness="1" Margin="10">
        <!-- 柔和的现代阴影 -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.12" Direction="270" Color="Black"/>
        </Border.Effect>

        <StackPanel Margin="20">

            <!-- 头部区域 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- 现代感提示图标：淡蓝色背景 + 蓝色字 -->
                    <Border Width="32" Height="32" CornerRadius="16" Background="#E6F2F8" Margin="0,0,12,0">
                        <TextBlock Text="i" Foreground="#0078D4" FontSize="18" FontFamily="Georgia" FontStyle="Italic" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="确定要关闭吗？" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#111111"/>
                </StackPanel>

                <!-- 右上角关闭按钮 -->
                <Button Grid.Column="1"
                        Width="28" Height="28"
                        VerticalAlignment="Top"
                        Style="{StaticResource WindowCloseButton}"
                        Click="CloseButton_Click">
                    <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Margin="0,1,0,0"/>
                </Button>
            </Grid>

            <!-- 选项区域 -->
            <StackPanel>

                <!-- 选项 1：最小化到托盘 -->
                <Button Style="{StaticResource ModernCardButton}" Click="MinimizeToTray_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 托盘图标 SVG -->
                        <Path Grid.Column="0" Data="M3,18 L21,18 L21,20 L3,20 Z M12,15 L7,10 L8.41,8.59 L11,11.17 L11,2 L13,2 L13,11.17 L15.59,8.59 L17,10 Z" 
                              Fill="#0078D4" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="最小化到托盘" FontSize="14" FontWeight="SemiBold" Foreground="#222222" Margin="0,0,0,2"/>
                            <TextBlock Text="程序将在后台继续运行" FontSize="12" Foreground="#888888"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <!-- 选项 2：直接退出 -->
                <Button Style="{StaticResource ModernCardButton}" Click="ExitApp_Click" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 退出图标 SVG -->
                        <Path Grid.Column="0" Data="M12,2 A10,10 0 0,0 2,12 A10,10 0 0,0 12,22 A10,10 0 0,0 22,12 A10,10 0 0,0 12,2 Z M12,4 A8,8 0 0,1 20,12 A8,8 0 0,1 12,20 A8,8 0 0,1 4,12 A8,8 0 0,1 12,4 Z M11,7 L11,13 L16,13 L16,11 L13,11 L13,7 Z" 
                              Fill="#E81123" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="直接退出" FontSize="14" FontWeight="SemiBold" Foreground="#222222" Margin="0,0,0,2"/>
                            <TextBlock Text="完全关闭并退出应用程序" FontSize="12" Foreground="#888888"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>

            <!-- 记住选择 -->
            <CheckBox x:Name="RememberCheck"
                      Content="记住我的选择"
                      FontSize="13"
                      Margin="2,0,0,0"/>
        </StackPanel>
    </Border>
</Window>