<UserControl x:Class="seamless_loop_music.UI.Views.NowPlayingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="TopBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Navigation Buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="30,20,0,10">
            <Button Content="{Binding [BtnBackToLibrary], Source={StaticResource Loc}}" 
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource TopBarButtonStyle}"/>
            
            <Button Content="{Binding [BtnEditLoop], Source={StaticResource Loc}}" 
                    Command="{Binding GoToEditCommand}"
                    Style="{StaticResource TopBarButtonStyle}"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,10,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <!-- Left: Artwork & Info -->
                <ColumnDefinition Width="1*"/>
                <!-- Right: Queue -->
            </Grid.ColumnDefinitions>

            <!-- Left: Large Album Cover & Info -->
            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Artwork Container: Centered square -->
                <Grid Grid.Row="0">
                    <Border CornerRadius="24" Background="#181825">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.4" ShadowDepth="10"/>
                        </Border.Effect>
                        <Grid Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" ClipToBounds="True">
                            <Image Source="{Binding AlbumCoverImage}" Stretch="UniformToFill" />

                            <!-- Fallback Text if no cover -->
                            <TextBlock Text="🎵" FontSize="80" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#313244"
                                       Visibility="{Binding AlbumCoverImage, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Track Info: Left aligned relative to artwork -->
                <StackPanel Grid.Row="1" Margin="0,30,0,0" HorizontalAlignment="Left">
                    <Viewbox HorizontalAlignment="Left" MaxHeight="50" StretchDirection="DownOnly" MaxWidth="450">
                        <TextBlock Text="{Binding CurrentTrack.DisplayName}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </Viewbox>
                    <TextBlock Text="{Binding CurrentTrack.Artist}" FontSize="20" Foreground="#BAC2DE" Margin="0,8,0,0" 
                               Opacity="0.8"/>
                    <TextBlock Text="{Binding CurrentTrack.Album}" FontSize="16" Foreground="#9399B2" Margin="0,5,0,0" 
                               Opacity="0.6"/>
                </StackPanel>
            </Grid>

            <!-- Right: Playback Queue -->
            <Border Grid.Column="1" Background="#181825" CornerRadius="24" Padding="15" Margin="20,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding [HeaderQueue], Source={StaticResource Loc}}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="15,10,0,20"/>

                    <ContentControl Grid.Row="1" prism:RegionManager.RegionName="NowPlayingListRegion" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
