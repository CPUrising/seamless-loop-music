<UserControl x:Class="seamless_loop_music.UI.Views.NowPlayingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="ImmersiveTopButton" TargetType="Button" BasedOn="{StaticResource ImmediateToolTipStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushImmersiveTextSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushImmersiveTextMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BrushImmersiveControl}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushImmersiveTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BrushImmersivePrimaryAction}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource ColorImmersiveGradientStart}" Offset="0"/>
                <GradientStop Color="{DynamicResource ColorImmersiveGradientEnd}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="30,20,0,10">
            <Button Content="{Binding [BtnBackToLibrary], Source={StaticResource Loc}}"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource ImmersiveTopButton}"/>
            <Button Content="{Binding [BtnEditLoop], Source={StaticResource Loc}}"
                    Command="{Binding GoToEditCommand}"
                    Style="{StaticResource ImmersiveTopButton}"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,10,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" HorizontalAlignment="Center">
                    <Border Background="{DynamicResource BrushImmersivePanel}" BorderBrush="{DynamicResource BrushImmersiveTextMuted}" BorderThickness="1" CornerRadius="8">
                        <Grid Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" ClipToBounds="True">
                            <Image Source="{Binding AlbumCoverImage}" Stretch="UniformToFill"/>
                            <md:PackIcon Kind="Music" Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource BrushImmersiveTextMuted}"
                                         Visibility="{Binding AlbumCoverImage, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Margin="0,30,0,0" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ContentControl Grid.Row="0" Style="{StaticResource Marquee}" Content="{Binding CurrentTrack.DisplayName}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrushImmersiveTextPrimary}" VerticalAlignment="Center"/>
                    <ContentControl Grid.Row="1" Style="{StaticResource Marquee}" Content="{Binding CurrentTrack.Artist}" FontSize="20" Foreground="{DynamicResource BrushImmersiveTextSecondary}" Margin="0,8,0,0" Opacity="0.9"/>
                    <ContentControl Grid.Row="2" Style="{StaticResource Marquee}" Content="{Binding CurrentTrack.Album}" FontSize="16" Foreground="{DynamicResource BrushImmersiveTextMuted}" Margin="0,5,0,0" Opacity="0.9"/>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="{DynamicResource BrushImmersivePanel}" BorderBrush="{DynamicResource BrushImmersiveTextMuted}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="20,0,0,0">
                <Border.Resources>
                    <SolidColorBrush x:Key="BrushTextPrimary" Color="{DynamicResource ColorImmersiveTextPrimary}"/>
                    <SolidColorBrush x:Key="BrushTextSecondary" Color="{DynamicResource ColorImmersiveTextSecondary}"/>
                    <SolidColorBrush x:Key="BrushTextMuted" Color="{DynamicResource ColorImmersiveTextMuted}"/>
                    <SolidColorBrush x:Key="BrushSurface" Color="{DynamicResource ColorImmersiveControl}"/>
                    <SolidColorBrush x:Key="BrushSurfaceHighlight" Color="{DynamicResource ColorImmersiveProgressTrack}"/>
                    <SolidColorBrush x:Key="BrushSelection" Color="{DynamicResource ColorSelection}"/>
                    <SolidColorBrush x:Key="BrushAccent" Color="{DynamicResource ColorImmersivePrimaryAction}"/>
                    <SolidColorBrush x:Key="BrushWarning" Color="{DynamicResource ColorImmersiveLoopMarker}"/>
                    <SolidColorBrush x:Key="BrushDanger" Color="{DynamicResource ColorImmersiveLoopMarker}"/>
                    <SolidColorBrush x:Key="BrushSeparator" Color="{DynamicResource ColorImmersiveProgressTrack}"/>
                </Border.Resources>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding [HeaderQueue], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushImmersiveTextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="5,4,0,16"/>
                    <ContentControl Grid.Row="1" prism:RegionManager.RegionName="NowPlayingListRegion"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
