<UserControl x:Class="seamless_loop_music.UI.Views.NowPlayingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="{StaticResource BrushBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Navigation Buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="30,20,0,10">
            <Button Content="{Binding [BtnBackToLibrary], Source={StaticResource Loc}}" 
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource PageTopButton}"/>
            
            <Button Content="{Binding [BtnEditLoop], Source={StaticResource Loc}}" 
                    Command="{Binding GoToEditCommand}"
                    Style="{StaticResource PageTopButton}"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,10,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <!-- Left: Artwork & Info -->
                <ColumnDefinition Width="1*"/>
                <!-- Right: Queue -->
            </Grid.ColumnDefinitions>

            <!-- Left: Large Album Cover & Info -->
            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Artwork Container: Centered square -->
                <Grid Grid.Row="0" HorizontalAlignment="Center">
                    <Border Background="{StaticResource BrushSurfaceDark}" CornerRadius="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.4" ShadowDepth="10"/>
                        </Border.Effect>
                        <Grid Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" ClipToBounds="True">
                            <Image Source="{Binding AlbumCoverImage}" Stretch="UniformToFill" />

                            <!-- Fallback Text if no cover -->
                            <TextBlock Text="🎵" FontSize="80" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource BrushSurface}"
                                       Visibility="{Binding AlbumCoverImage, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Track Info: Left aligned relative to artwork -->
                <Grid Grid.Row="1" Margin="0,30,0,0" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                        <ContentControl Style="{StaticResource Marquee}"  
                            Content="{Binding CurrentTrack.DisplayName}" 
                            FontSize="28" 
                            FontWeight="Bold" 
                            Foreground="{StaticResource BrushTextPrimary}"
                            VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Grid.Row="1" HorizontalAlignment="Stretch">
                        <ContentControl Style="{StaticResource Marquee}"
                        Content="{Binding CurrentTrack.Artist}" 
                        FontSize="20" 
                        Foreground="{StaticResource BrushTextPrimary}"
                        Margin="0,8,0,0" 
                        Opacity="0.8"/>
                    </Grid>
                    <Grid Grid.Row="2" HorizontalAlignment="Stretch">
                        <ContentControl Style="{StaticResource Marquee}"  
                        Content="{Binding CurrentTrack.Album}" 
                        FontSize="16" 
                        Foreground="{StaticResource BrushTextSecondary}"
                        Margin="0,5,0,0" 
                        Opacity="0.6"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Right: Playback Queue -->
            <Border Grid.Column="1" Background="{StaticResource BrushSurfaceDark}" CornerRadius="24" Padding="15" Margin="20,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding [HeaderQueue], Source={StaticResource Loc}}" Foreground="{StaticResource BrushTextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="15,10,0,20"/>

                    <ContentControl Grid.Row="1" prism:RegionManager.RegionName="NowPlayingListRegion" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
