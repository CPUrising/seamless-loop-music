<UserControl x:Class="seamless_loop_music.UI.Views.NowPlayingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar: Back Button -->
        <Button Grid.Row="0" 
                Content="← 返回库" 
                Command="{Binding GoBackCommand}"
                HorizontalAlignment="Left" 
                Margin="30,20,0,10"
                Padding="15,8"
                Background="#313244" 
                Foreground="White" 
                BorderThickness="0"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="10" 
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#45475A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <Grid Grid.Row="1" Margin="30,10,30,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Large Album Cover & Info -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="20" Background="#181825" Padding="20">
                    <Grid>
                        <Border x:Name="CoverBorder" CornerRadius="15" ClipToBounds="True">
                            <Image Source="{Binding AlbumCoverImage}" Stretch="UniformToFill">
                                <Image.Effect>
                                    <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.5" ShadowDepth="10"/>
                                </Image.Effect>
                            </Image>
                        </Border>
                        <!-- Fallback Text if no cover -->
                        <TextBlock Text="🎵" FontSize="120" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#313244"
                                   Visibility="{Binding AlbumCoverImage, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,25,0,0">
                    <TextBlock Text="{Binding CurrentTrack.DisplayName}" FontSize="32" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentTrack.Artist}" FontSize="20" Foreground="#BAC2DE" Margin="0,5,0,0" Opacity="0.8"/>
                    <TextBlock Text="{Binding CurrentTrack.Album}" FontSize="16" Foreground="#9399B2" Margin="0,5,0,0" Opacity="0.6"/>
                </StackPanel>
            </Grid>

            <!-- Right: Playback Queue -->
            <Border Grid.Column="1" Background="#181825" CornerRadius="20" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="待播清单" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="15,10,0,15"/>
                    
                    <ContentControl Grid.Row="1" prism:RegionManager.RegionName="NowPlayingListRegion" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
