<UserControl x:Class="seamless_loop_music.UI.Views.PlaybackControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="ControlToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4">
                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FAB387"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Progress Area -->
        <StackPanel Grid.Row="0" Margin="0,15">
            <TextBlock Text="{Binding TimeDisplay}" HorizontalAlignment="Right" FontSize="18" FontWeight="Light" Foreground="#CDD6F4"/>
            <Slider x:Name="ProgressBar" Value="{Binding ProgressValue}" Maximum="1000" IsMoveToPointEnabled="True" Margin="0,5,0,0"
                    Thumb.DragStarted="ProgressBar_DragStarted" Thumb.DragCompleted="ProgressBar_DragCompleted"
                    ValueChanged="ProgressBar_ValueChanged"/>
        </StackPanel>

        <!-- Bottom Bar: Playback Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <!-- Left: Current Track Info (Clickable) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border Width="45" Height="45" CornerRadius="4" Margin="10,0,10,0" Background="#2A2A3E">
                    <Image Source="{Binding AlbumCoverImage}" Stretch="UniformToFill"/>
                </Border>
                <Button Command="{Binding OpenDetailCommand}" 
                        Background="Transparent" BorderThickness="0" 
                        Cursor="Hand" Padding="5" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentTrack.DisplayName, FallbackValue='未选择曲目'}" 
                                   FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4" 
                                   MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentTrack.Artist, FallbackValue='未知艺术家'}" 
                                   FontSize="12" Foreground="#CDD6F4" Opacity="0.6"
                                   MaxWidth="200" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="&lt;&lt;" Command="{Binding PrevCommand}" Width="60" Margin="5"/>
                <Button Content="{Binding PlayButtonContent}" Command="{Binding PlayCommand}" Width="110" Height="45" Margin="15,5" 
                        FontWeight="Bold" Background="#A6E3A1" Foreground="#11111B"/>

                <Button Content="&gt;&gt;" Command="{Binding NextCommand}" Width="60" Margin="15,5,5,5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ToggleButton Content="{Binding [FeatureLoop], Source={StaticResource Loc}}" 
                              IsChecked="{Binding IsFeatureLoopEnabled}"
                              Style="{StaticResource ControlToggleStyle}"
                              Margin="0,0,10,0"
                              ToolTip="{Binding [FeatureLoopToolTip], Source={StaticResource Loc}}"/>
                <TextBlock Text="Vol:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Opacity="0.5" Foreground="#CDD6F4"/>
                <Slider Width="80" Minimum="0" Maximum="100" Value="{Binding VolumeValue}" IsMoveToPointEnabled="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
