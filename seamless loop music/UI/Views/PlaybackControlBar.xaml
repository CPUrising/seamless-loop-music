<UserControl x:Class="seamless_loop_music.UI.Views.PlaybackControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:controls="clr-namespace:seamless_loop_music.UI.Controls"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="ControlToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource ImmediateToolTipStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BrushSurface}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ControlButtonStyle" TargetType="Button" BasedOn="{StaticResource ImmediateToolTipStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BrushSurface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Progress Area -->
        <controls:ProgressControls Grid.Row="0" Margin="0,10"/>

        <!-- Bottom Bar: Playback Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <!-- Left: Current Track Info -->
            <Grid Grid.Column="0" HorizontalAlignment="Stretch">
                <controls:TrackInfoControl x:Name="TrackInfo" ArtSize="45" IsClickable="True" ShowAlbum="False" CoverImage="{Binding AlbumCoverImage}"/>
                <!--<Button Command="{Binding RateCommand}"
                        CommandParameter="{Binding CurrentTrack}"
                        Style="{StaticResource ControlButtonStyle}"
                        Margin="100,0,0,0"
                        ToolTip="{Binding [TipRateCurrent], Source={StaticResource Loc}}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Star" Width="22" Height="22" Foreground="{DynamicResource BrushWarning}"/>
                        <TextBlock Text="{Binding CurrentTrack.Rating}" 
                                   Foreground="{DynamicResource BrushWarning}"
                                   VerticalAlignment="Center" FontWeight="Bold" Margin="4,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTrack.Rating}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>-->
            </Grid>

            <!-- Center: Controls -->
            <controls:PlaybackControls Grid.Column="1" HorizontalAlignment="Center"/>

            <!-- Right: Extras & Volume -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentTrack.Rating}" 
                                   Foreground="{DynamicResource BrushWarning}"
                                   VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTrack.Rating}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Command="{Binding RateCommand}"
                        CommandParameter="{Binding CurrentTrack}"
                        Style="{StaticResource ControlButtonStyle}"
                        Width="40" Height="40" Margin="0,0,0,0"
                        ToolTip="{Binding [TipRateCurrent], Source={StaticResource Loc}}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Star" Width="22" Height="22" Foreground="{DynamicResource BrushWarning}"/>

                    </StackPanel>
                </Button>
                <Button Command="{Binding ChangePlayModeCommand}"
                        Style="{StaticResource ControlButtonStyle}"
                        Foreground="{DynamicResource BrushTextSecondary}"
                        Margin="0,0,8,0" Padding="5" Height="40" Width="40"
                        ToolTip="{Binding PlayModeToolTipText}">
                    <md:PackIcon Kind="{Binding PlayModeIcon}" Width="22" Height="22"/>
                </Button>
                <ToggleButton IsChecked="{Binding IsSeamlessLoopEnabled}"
                               Style="{StaticResource ControlToggleStyle}"
                               Width="40" Height="40" Margin="0,0,10,0"
                               ToolTip="{Binding [FeatureLoop], Source={StaticResource Loc}}">
                    <md:PackIcon Kind="Infinity" Width="22" Height="22"/>
                </ToggleButton>
                <controls:VolumeControls SliderWidth="80"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
