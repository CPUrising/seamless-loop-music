<UserControl x:Class="seamless_loop_music.UI.Views.PlaybackControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Progress Area -->
        <StackPanel Grid.Row="0" Margin="0,15">
            <TextBlock Text="{Binding TimeDisplay}" HorizontalAlignment="Right" FontSize="18" FontWeight="Light" Foreground="#CDD6F4"/>
            <Slider Value="{Binding ProgressValue}" Maximum="1000" IsMoveToPointEnabled="True" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Bottom Bar: Playback Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="&lt;&lt;" Command="{Binding PrevCommand}" Width="60" Margin="5"/>
                <Button Content="{Binding PlayButtonContent}" Command="{Binding PlayCommand}" Width="110" Height="45" Margin="15,5" 
                        FontWeight="Bold" Background="#A6E3A1" Foreground="#11111B"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="75" Margin="5"/>
                <Button Content="&gt;&gt;" Command="{Binding NextCommand}" Width="60" Margin="15,5,5,5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Vol:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Opacity="0.5" Foreground="#CDD6F4"/>
                <Slider Width="80" Minimum="0" Maximum="100" Value="{Binding VolumeValue}" IsMoveToPointEnabled="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
