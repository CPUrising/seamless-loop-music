<UserControl x:Class="seamless_loop_music.UI.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:seamless_loop_music.UI.Views"
             xmlns:converters="clr-namespace:seamless_loop_music.UI.Converters"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BindingProxy x:Key="LibraryVmProxy" Data="{Binding}"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource BrushBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65"/>  <!-- Column 0: Navigation -->
            <ColumnDefinition Width="280"/> <!-- Column 1: Middle Items -->
            <ColumnDefinition Width="*"/>   <!-- Column 2: Tracks -->
        </Grid.ColumnDefinitions>

        <!-- Column 0: Minimal Navigation -->
        <Border Grid.Column="0" Background="#181825" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
            <ListBox Background="Transparent" BorderThickness="0" Margin="0,20,0,0"
                     ItemsSource="{Binding NavigationCategories}"
                     SelectedItem="{Binding SelectedCategory}"
                     HorizontalContentAlignment="Center"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarListBoxItem}"/>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- Column 1: Category Items or Folder Browser -->
        <Grid Grid.Column="1" Background="{StaticResource BrushBackground}">
            <!-- 1. Normal View (Albums/Artists/Playlists) -->
            <Grid Visibility="{Binding IsFolderCategorySelected, Converter={StaticResource NullToVisibilityInverseConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Search -->
                    <RowDefinition Height="*"/>    <!-- List -->
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Margin="15,20,15,10" Background="{StaticResource BrushSurface}" CornerRadius="6" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{StaticResource IconSearch}" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource BrushTextSecondary}" IsHitTestVisible="False" FontSize="12"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding MiddleFilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0" 
                                 Foreground="White" VerticalContentAlignment="Center"
                                 FontSize="13" CaretBrush="{StaticResource BrushAccent}"
                                 Margin="2,0,5,0"/>
                        
                        <Button Grid.Column="2" 
                                Style="{StaticResource GhostIconButton}"
                                Content="{StaticResource IconAdd}" 
                                FontSize="20"
                                ToolTip="{Binding [ToolTipAddPlaylist], Source={StaticResource Loc}}"
                                Command="{Binding CreatePlaylistCommand}"
                                Visibility="{Binding IsPlaylistCategorySelected, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <ListBox x:Name="CategoryListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="5,0,5,10"
                         ItemsSource="{Binding CategoryItemsView}"
                         SelectedItem="{Binding SelectedCategoryItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="CategoryListBox_SelectionChanged">
                    <ListBox.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" 
                                      Command="{Binding PlayCategoryItemCommand}" 
                                      CommandParameter="{Binding SelectedCategoryItem}"/>
                    </ListBox.InputBindings>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListBoxItem_PreviewMouseRightButtonDown"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu Background="{StaticResource BrushSurface}" BorderThickness="0" Padding="4" Foreground="{StaticResource BrushTextPrimary}">
                                        <MenuItem Header="{Binding [MenuRefresh], Source={StaticResource Loc}}" 
                                                  Command="{Binding Data.RefreshPlaylistCommand, Source={StaticResource LibraryVmProxy}}"/>
                                        <Separator Background="{StaticResource BrushSeparator}" Margin="4,2"/>
                                        <MenuItem Header="{Binding [MenuRename], Source={StaticResource Loc}}" 
                                                  Command="{Binding Data.RenamePlaylistCommand, Source={StaticResource LibraryVmProxy}}"/>
                                        <MenuItem Header="{Binding [MenuDeletePlaylist], Source={StaticResource Loc}}" 
                                                  Command="{Binding Data.DeletePlaylistCommand, Source={StaticResource LibraryVmProxy}}"
                                                  Foreground="{StaticResource BrushDanger}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Margin="8,2" Padding="8,6">
                                            <Grid Background="Transparent" 
                                                  ToolTip="{Binding Name}"
                                                  ToolTipService.InitialShowDelay="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Thumbnail Placeholder -->
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="4" Background="{StaticResource BrushSurface}">
                                                    <TextBlock Text="{Binding Icon, TargetNullValue={StaticResource IconDisc}}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Type}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSurface}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSurfaceHighlight}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>

            <!-- 2. Folder Browser View -->
            <Grid Visibility="{Binding IsFolderCategorySelected, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Root Selector -->
                    <RowDefinition Height="Auto"/> <!-- Breadcrumbs -->
                    <RowDefinition Height="*"/>    <!-- Subfolders -->
                </Grid.RowDefinitions>

                <ComboBox Grid.Row="0" Margin="15,20,15,5" 
                          ItemsSource="{Binding RootFolders}"
                          SelectedItem="{Binding SelectedRoot}"
                          Style="{StaticResource FlatComboBoxStyle}"
                          Height="36">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" Margin="0,0,8,0" Opacity="0.7"/>
                                <TextBlock Text="{Binding Name}" ToolTip="{Binding Path}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Breadcrumbs -->
                <ItemsControl Grid.Row="1" Margin="15,5,15,10" ItemsSource="{Binding Breadcrumbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource ModernTextButton}" 
                                        Content="{Binding Name}" 
                                        Command="{Binding Data.NavigateToPathCommand, Source={StaticResource LibraryVmProxy}}"
                                        CommandParameter="{Binding Path}"
                                        FontSize="12" Opacity="0.8"/>
                                <TextBlock Text="›" Margin="4,0" Foreground="{StaticResource BrushTextSecondary}" 
                                           Visibility="{Binding IsRoot, Converter={StaticResource NullToVisibilityInverseConverter}}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ListBox Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="5,0,5,10"
                         ItemsSource="{Binding Subfolders}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Margin="8,2" Padding="8,6">
                                            <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch"
                                                    Command="{Binding DataContext.NavigateToPathCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding Path}">
                                                <Grid Background="Transparent" ToolTip="{Binding Path}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="📁" FontSize="18" VerticalAlignment="Center" Opacity="0.6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Button>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushSurfaceHighlight}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Column 2: Content Area (Track List / Detail View) -->
        <Border Grid.Column="2" Background="Transparent">
            <ContentControl prism:RegionManager.RegionName="LibraryContentRegion" />
        </Border>
    </Grid>
</UserControl>
