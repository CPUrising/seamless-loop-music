<UserControl x:Class="seamless_loop_music.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="1000">
    <UserControl.Resources>
        <!-- Settings navigation rail: first-level settings sections. -->
        <Style x:Key="SettingsNavItem" TargetType="ListBoxItem" BasedOn="{StaticResource ImmediateToolTipStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="10" Padding="12,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushSurface}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushSurfaceHighlight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BrushBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: settings first-level navigation rail. -->
        <Border Grid.Column="0" Background="{DynamicResource BrushSurfaceDark}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,1,0" Padding="22,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="{Binding [SettingsTitle], Source={StaticResource Loc}}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontSize="28"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding [SettingsSub], Source={StaticResource Loc}}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource SettingsNavItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Prism-hosted settings section content. -->
        <Border Grid.Column="1" Padding="28,24,32,24">
            <ContentControl prism:RegionManager.RegionName="SettingsContentRegion"/>
        </Border>
    </Grid>
</UserControl>
