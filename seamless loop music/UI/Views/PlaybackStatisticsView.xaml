<UserControl x:Class="seamless_loop_music.UI.Views.PlaybackStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:seamless_loop_music.Models"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="StatisticsPeriodButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,5"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Background" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Background" Property="Background" Value="{DynamicResource BrushSurfaceHighlight}"/><Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="StatisticsPeriodButtonDay" TargetType="Button" BasedOn="{StaticResource StatisticsPeriodButton}"><Style.Triggers><DataTrigger Binding="{Binding IsDaySelected}" Value="True"><Setter Property="Background" Value="{DynamicResource BrushAccent}"/><Setter Property="Foreground" Value="{DynamicResource BrushBackground}"/></DataTrigger></Style.Triggers></Style>
        <Style x:Key="StatisticsPeriodButtonWeek" TargetType="Button" BasedOn="{StaticResource StatisticsPeriodButton}"><Style.Triggers><DataTrigger Binding="{Binding IsWeekSelected}" Value="True"><Setter Property="Background" Value="{DynamicResource BrushAccent}"/><Setter Property="Foreground" Value="{DynamicResource BrushBackground}"/></DataTrigger></Style.Triggers></Style>
        <Style x:Key="StatisticsPeriodButtonMonth" TargetType="Button" BasedOn="{StaticResource StatisticsPeriodButton}"><Style.Triggers><DataTrigger Binding="{Binding IsMonthSelected}" Value="True"><Setter Property="Background" Value="{DynamicResource BrushAccent}"/><Setter Property="Foreground" Value="{DynamicResource BrushBackground}"/></DataTrigger></Style.Triggers></Style>
        <Style x:Key="StatisticsPeriodButtonYear" TargetType="Button" BasedOn="{StaticResource StatisticsPeriodButton}"><Style.Triggers><DataTrigger Binding="{Binding IsYearSelected}" Value="True"><Setter Property="Background" Value="{DynamicResource BrushAccent}"/><Setter Property="Foreground" Value="{DynamicResource BrushBackground}"/></DataTrigger></Style.Triggers></Style>
        <Style x:Key="StatisticsPeriodButtonAll" TargetType="Button" BasedOn="{StaticResource StatisticsPeriodButton}"><Style.Triggers><DataTrigger Binding="{Binding IsAllSelected}" Value="True"><Setter Property="Background" Value="{DynamicResource BrushAccent}"/><Setter Property="Foreground" Value="{DynamicResource BrushBackground}"/></DataTrigger></Style.Triggers></Style>
        <Style x:Key="StatisticsBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/><Setter Property="Maximum" Value="100"/><Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/><Setter Property="Background" Value="{DynamicResource BrushSurfaceHighlight}"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ProgressBar"><Border Background="{TemplateBinding Background}" CornerRadius="3" ClipToBounds="True"><Grid x:Name="PART_Track"><Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="3" HorizontalAlignment="Left"/></Grid></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="StatisticsListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Row" Background="Transparent" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Row" Property="Background" Value="{DynamicResource BrushSurface}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BrushBackground}" Margin="28,24,32,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="{Binding [PlaybackStatisticsTitle], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,16,0"/>
            <Border Grid.Column="1" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="6" Padding="3" HorizontalAlignment="Right" MaxWidth="440">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource StatisticsPeriodButtonDay}" Content="{Binding [StatisticsDay], Source={StaticResource Loc}}" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static models:PlaybackStatisticsPeriod.Day}"/>
                    <Button Grid.Column="1" Style="{StaticResource StatisticsPeriodButtonWeek}" Content="{Binding [StatisticsWeek], Source={StaticResource Loc}}" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static models:PlaybackStatisticsPeriod.Week}"/>
                    <Button Grid.Column="2" Style="{StaticResource StatisticsPeriodButtonMonth}" Content="{Binding [StatisticsMonth], Source={StaticResource Loc}}" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static models:PlaybackStatisticsPeriod.Month}"/>
                    <Button Grid.Column="3" Style="{StaticResource StatisticsPeriodButtonYear}" Content="{Binding [StatisticsYear], Source={StaticResource Loc}}" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static models:PlaybackStatisticsPeriod.Year}"/>
                    <Button Grid.Column="4" Style="{StaticResource StatisticsPeriodButtonAll}" Content="{Binding [StatisticsAll], Source={StaticResource Loc}}" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static models:PlaybackStatisticsPeriod.All}"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ClipToBounds="True" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="60"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="54" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="6" Padding="16,6"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding HasStatistics}" Value="True"/><Condition Binding="{Binding IsLoading}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></Border.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock Text="{Binding [StatisticsListeningDuration], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="10"/><TextBlock Text="{Binding TotalListeningDurationText, Mode=OneWay}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,0"/></StackPanel><Border Grid.Column="1" Background="{DynamicResource BrushBorder}" Margin="12,3"/><StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0"><TextBlock Text="{Binding [StatisticsTrackedTracks], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="10"/><TextBlock Text="{Binding TrackedTrackCountText, Mode=OneWay}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,0"/></StackPanel></Grid></Border>
            <TextBlock Grid.Row="1" Text="{Binding [StatisticsTopFive], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="14" FontWeight="SemiBold" Margin="0,7,0,3"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding HasStatistics}" Value="True"/><Condition Binding="{Binding IsLoading}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
            <ListBox Grid.Row="2" ItemsSource="{Binding TopTracks}" Background="Transparent" BorderThickness="0" Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource StatisticsListItem}"><ListBox.Style><Style TargetType="ListBox"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding HasStatistics}" Value="True"/><Condition Binding="{Binding IsLoading}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></ListBox.Style><ListBox.ItemTemplate><DataTemplate><Grid Height="29"><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="4"/></Grid.RowDefinitions><TextBlock Grid.Column="0" Grid.RowSpan="2" Text="{Binding Rank, Mode=OneWay}" Foreground="{DynamicResource BrushAccent}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/><Border Grid.Column="1" Grid.RowSpan="2" Width="23" Height="23" CornerRadius="3" Background="{DynamicResource BrushSurfaceHighlight}" ClipToBounds="True" VerticalAlignment="Center"><Grid><TextBlock Text="{StaticResource IconMusic}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/><Image Source="{Binding CoverPath, Mode=OneWay}" Stretch="UniformToFill"/></Grid></Border><TextBlock Grid.Column="2" Text="{Binding Title, Mode=OneWay}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="6,0,7,0"/><TextBlock Grid.Column="3" Text="{Binding DurationText, Mode=OneWay}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/><ProgressBar Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" Style="{StaticResource StatisticsBar}" Value="{Binding BarPercent, Mode=OneWay}" Opacity="{Binding BarOpacity, Mode=OneWay}" Margin="6,0,0,2"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox>
            <Border Grid.Row="3" Margin="0,7,0,3" Padding="0,5,0,0" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding HasStatistics}" Value="True"/><Condition Binding="{Binding IsLoading}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></Border.Style><TextBlock Text="{Binding [StatisticsMostListened], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="14" FontWeight="SemiBold"/></Border>
            <ListBox Grid.Row="4" ItemsSource="{Binding MostListenedTracks}" Background="Transparent" BorderThickness="0" Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ItemContainerStyle="{StaticResource StatisticsListItem}"><ListBox.Style><Style TargetType="ListBox"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding HasStatistics}" Value="True"/><Condition Binding="{Binding IsLoading}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></ListBox.Style><ListBox.ItemTemplate><DataTemplate><Grid Height="54"><Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="{Binding Rank, Mode=OneWay}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/><Border Grid.Column="1" Width="40" Height="40" CornerRadius="4" Background="{DynamicResource BrushSurfaceHighlight}" ClipToBounds="True" VerticalAlignment="Center"><Grid><TextBlock Text="{StaticResource IconMusic}" Foreground="{DynamicResource BrushTextMuted}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/><Image Source="{Binding CoverPath, Mode=OneWay}" Stretch="UniformToFill"/></Grid></Border><StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,8,0"><TextBlock Text="{Binding Title, Mode=OneWay}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"><Run Text="{Binding Artist, Mode=OneWay}"/><Run Text="  "/><Run Text="{Binding Album, Mode=OneWay}"/></TextBlock></StackPanel><TextBlock Grid.Column="3" Text="{Binding DurationText, Mode=OneWay}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right" Margin="8,0,0,0"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox>
            <StackPanel Grid.RowSpan="5" HorizontalAlignment="Center" VerticalAlignment="Center"><StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsLoading}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></StackPanel.Style><ProgressBar Width="112" Height="3" IsIndeterminate="True" Foreground="{DynamicResource BrushAccent}"/><TextBlock Text="{Binding [StatisticsLoading], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/></StackPanel>
            <TextBlock Grid.RowSpan="5" Text="{Binding [StatisticsEmpty], Source={StaticResource Loc}}" Foreground="{DynamicResource BrushTextSecondary}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding IsLoading}" Value="False"/><Condition Binding="{Binding HasStatistics}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
        </Grid>
    </Grid>
</UserControl>
