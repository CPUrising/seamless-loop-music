<Window x:Class="seamless_loop_music.UI.Views.AddToPlaylistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding [MenuAddToPlaylist], Source={StaticResource Loc}}"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="Microsoft YaHei">

    <Window.Resources>
        <!-- 使用全局样式，这里可以添加特定的覆写（如有必要） -->
    </Window.Resources>

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock Text="{Binding [DialogSelectPlaylist], Source={StaticResource Loc}}" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,6"/>
        <TextBlock x:Name="TxtSubtitle" FontSize="12" Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,16"/>

        <!-- 现有歌单列表 -->
        <Border Background="{StaticResource BrushSurfaceDark}" CornerRadius="8" MaxHeight="260">
            <ListBox x:Name="PlaylistListBox"
                     Background="Transparent" BorderThickness="0"
                     Padding="4" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- 新建歌单区 -->
        <Expander x:Name="NewPlaylistExpander" Header="{Binding [PromptNewPlaylist], Source={StaticResource Loc}}" Foreground="{StaticResource BrushAccent}" Margin="0,14,0,0"
                  BorderThickness="0">
            <StackPanel Margin="0,8,0,0">
                <TextBox x:Name="TxtNewPlaylistName"
                         Style="{StaticResource ModernTextBox}"/>
                <TextBlock Text="{Binding [PromptEnterNameToCreate], Source={StaticResource Loc}}" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="4,6,0,0"/>
            </StackPanel>
        </Expander>

        <!-- 操作按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnCancel" Content="{Binding [BtnCancel], Source={StaticResource Loc}}" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnConfirm" Content="{Binding [BtnAdd], Source={StaticResource Loc}}" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Click="BtnConfirm_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
