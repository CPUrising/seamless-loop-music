<Window x:Class="seamless_loop_music.UI.Views.Settings.ClearLocalSyncDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="清除本机同步数据"
        Width="384"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Dialog_MouseLeftButtonDown"
        FontFamily="Microsoft YaHei, Segoe UI, sans-serif">

    <Window.Resources>
        <Style x:Key="WindowCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8A8A8A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FCE8E8"/>
                                <Setter Property="Foreground" Value="#D13438"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F5CFCF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#2F2F2F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F3F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerActionButton" TargetType="Button">
            <Setter Property="Background" Value="#D13438"/>
            <Setter Property="BorderBrush" Value="#B12A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C5282C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A91F23"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" BorderBrush="#EAEAEA" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.12" Direction="270" Color="Black"/>
        </Border.Effect>

        <StackPanel Margin="20">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="16" Background="#FCE8E8" Margin="0,0,12,0">
                        <Path Data="M 12 3 L 22 20 H 2 Z M 12 8 L 12 13 M 12 16.5 L 12 16.6"
                              Stroke="#D13438"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Width="16"
                              Height="16"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="清除本机同步数据" FontSize="16" FontWeight="SemiBold" Foreground="#111111"/>
                        <TextBlock Text="这会删除本机保存的同步信息，不会影响歌曲文件。" FontSize="12" Foreground="#7A7A7A" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Width="28"
                        Height="28"
                        VerticalAlignment="Top"
                        Style="{StaticResource WindowCloseButton}"
                        Click="CloseButton_Click">
                    <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.5"
                          Margin="0,1,0,0"/>
                </Button>
            </Grid>

            <Border Background="#FFF8F8" BorderBrush="#F0C8C8" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="请选择要清除的内容" FontSize="13" FontWeight="SemiBold" Foreground="#4A1F1F" Margin="0,0,0,10"/>
                    <CheckBox x:Name="PlaylistsCheckBox" Content="歌单" Foreground="#222222" Margin="0,0,0,10"/>
                    <CheckBox x:Name="LoopPointsCheckBox" Content="循环点" Foreground="#222222" Margin="0,0,0,10"/>
                    <CheckBox x:Name="RatingsCheckBox" Content="评分" Foreground="#222222"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Width="88"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryActionButton}"
                        Click="Cancel_Click"/>
                <Button Content="确认清除"
                        Width="96"
                        Style="{StaticResource DangerActionButton}"
                        Click="Confirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
