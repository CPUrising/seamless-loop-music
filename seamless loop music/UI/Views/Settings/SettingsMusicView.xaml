<UserControl x:Class="seamless_loop_music.UI.Views.Settings.SettingsMusicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="720">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Page header -->
            <TextBlock Text="{Binding [SettingsMusic], Source={StaticResource Loc}}"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource BrushTextPrimary}"/>
            <TextBlock Text="{Binding [SettingsMusicSub], Source={StaticResource Loc}}"
                       FontSize="13"
                       Foreground="{StaticResource BrushTextSecondary}"
                       Margin="0,6,0,22"/>

            <!-- Music folders card -->
            <Border Style="{StaticResource SurfaceCard}"
                    Padding="20"
                    Margin="0,0,0,16"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#1AFFFFFF">
                <StackPanel>

                    <!-- Card header row: label + folder count badge -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding [MusicFoldersHeader], Source={StaticResource Loc}}"
                                   Style="{StaticResource SectionHeaderText}"/>

                        <!-- Folder count badge -->
                        <Border Grid.Column="1"
                                Background="#18FFFFFF"
                                BorderBrush="#15FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,3">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding MusicFolders.Count}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                                <TextBlock Text=" folders"
                                           FontSize="12"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding [MusicFoldersSub], Source={StaticResource Loc}}"
                               Style="{StaticResource SectionDescriptionText}"
                               Margin="0,0,0,14"/>

                    <!-- Folder list: Border.Clip provides true rounded clipping in WPF -->
                    <Border x:Name="FolderListBorder"
                            Background="{StaticResource BrushSurfaceDark}"
                            BorderBrush="#10FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,0,14"
                            SizeChanged="FolderListBorder_SizeChanged">
                        <ListBox ItemsSource="{Binding MusicFolders}"
                                 SelectedItem="{Binding SelectedFolder}"
                                 Tag="{Binding}"
                                 Background="Transparent"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 BorderThickness="0"
                                 MaxHeight="220"
                                 Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 TextOptions.TextFormattingMode="Display">

                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <!-- Selected left-edge accent bar -->
                                                    <Border x:Name="AccentBar"
                                                            Width="2"
                                                            HorizontalAlignment="Left"
                                                            Background="#4D6EA8F5"
                                                            CornerRadius="2"
                                                            Margin="4,2,0,2"
                                                            Visibility="Collapsed"/>

                                                    <Border x:Name="ItemBorder"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            CornerRadius="6"
                                                            Margin="4,2"
                                                            Padding="10,0,10,0">
                                                        <Grid Height="38">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Folder icon -->
                                                            <TextBlock Grid.Column="0"
                                                                       Text="&#xE8B7;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="14"
                                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,10,0"/>

                                                            <!-- Path -->
                                                            <ContentPresenter Grid.Column="1"
                                                                              VerticalAlignment="Center"/>

                                                            <!-- Inline remove button, visible on hover/select -->
                                                            <Button x:Name="RemoveBtn"
                                                                    Grid.Column="2"
                                                                    Command="{Binding Tag.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                    CommandParameter="{Binding}"
                                                                    Visibility="Collapsed"
                                                                    Width="24" Height="24"
                                                                    Padding="0"
                                                                    Margin="4,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="Remove"
                                                                    Cursor="Hand"
                                                                    Background="Transparent"
                                                                    BorderThickness="0">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="BtnBorder"
                                                                                Background="Transparent"
                                                                                CornerRadius="4"
                                                                                Width="24" Height="24">
                                                                            <TextBlock Text="&#xE711;"
                                                                                       FontFamily="Segoe MDL2 Assets"
                                                                                       FontSize="10"
                                                                                       Foreground="#CC5555"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                            <VisualStateManager.VisualStateGroups>
                                                                                <VisualStateGroup x:Name="CommonStates">
                                                                                    <VisualState x:Name="MouseOver">
                                                                                        <Storyboard>
                                                                                            <ColorAnimation Storyboard.TargetName="BtnBorder"
                                                                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                                                                            To="#22CC5555" Duration="0:0:0.1"/>
                                                                                        </Storyboard>
                                                                                    </VisualState>
                                                                                    <VisualState x:Name="Normal"/>
                                                                                </VisualStateGroup>
                                                                            </VisualStateManager.VisualStateGroups>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#08FFFFFF"/>
                                                        <Setter TargetName="RemoveBtn" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#0FFFFFFF"/>
                                                        <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="RemoveBtn" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Button Content="{Binding [BtnAddFolder], Source={StaticResource Loc}}"
                                Command="{Binding AddFolderCommand}"
                                Style="{StaticResource ProminentSecondaryButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="{Binding [BtnRemove], Source={StaticResource Loc}}"
                                Command="{Binding RemoveFolderCommand}"
                                Style="{StaticResource ProminentDangerButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="{Binding ScanButtonText}"
                                Command="{Binding ScanCommand}"
                                Style="{StaticResource ProminentPrimaryButton}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
