<Window x:Class="seamless_loop_music.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="500" Width="600"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Microsoft YaHei"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#89B4FA" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#313244" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Music Folders" FontSize="16" FontWeight="SemiBold" Foreground="#CBA6F7" Margin="0,0,0,10"/>
                        <TextBlock Text="Add folders containing your music files" Foreground="#7F849C" FontSize="12" Margin="0,0,0,10"/>

                        <ListBox x:Name="lstFolders" Background="#181825" Foreground="#CDD6F4" BorderThickness="0" MaxHeight="150" Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#CDD6F4" Padding="5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnAddFolder" Content="Add Folder" Background="#45475A" Foreground="#CDD6F4" Padding="15,8" BorderThickness="0" Click="BtnAddFolder_Click"/>
                            <Button x:Name="btnRemoveFolder" Content="Remove" Background="#45475A" Foreground="#CDD6F4" Padding="15,8" BorderThickness="0" Margin="10,0,0,0" Click="BtnRemoveFolder_Click"/>
                            <Button x:Name="btnScan" Content="Scan Now" Background="#89B4FA" Foreground="#1E1E2E" Padding="15,8" BorderThickness="0" Margin="10,0,0,0" Click="BtnScan_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border Background="#313244" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Data Management" FontSize="16" FontWeight="SemiBold" Foreground="#CBA6F7" Margin="0,0,0,10"/>
                        <TextBlock Text="Sync loop points and playlists from an older LoopData.db file" Foreground="#7F849C" FontSize="12" Margin="0,0,0,15" TextWrapping="Wrap"/>

                        <Button x:Name="btnSync" Content="Sync from Old Database" Background="#45475A" Foreground="#CDD6F4" Padding="15,8" BorderThickness="0" HorizontalAlignment="Left" Click="BtnSync_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Close" HorizontalAlignment="Right" Padding="20,8" Click="BtnClose_Click"/>
    </Grid>
</Window>