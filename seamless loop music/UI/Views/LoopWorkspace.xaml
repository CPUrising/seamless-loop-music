<UserControl x:Class="seamless_loop_music.UI.Views.LoopWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:seamless_loop_music.UI.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BindingProxy x:Key="VmProxy" Data="{Binding}"/>
        <!-- 使用全局设计系统样式 -->
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: File Info -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding [FilePathTitle], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
            <TextBox Text="{Binding FilePath, Mode=OneWay}" 
                      FontSize="14" FontWeight="Bold" Margin="-2,2,0,10" 
                      Background="Transparent" Foreground="{StaticResource BrushTextPrimary}" BorderThickness="0" Padding="0"
                      IsReadOnly="True" TextWrapping="NoWrap" Cursor="IBeam"/>

            <Border Background="{StaticResource BrushSurface}" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushAccent}" FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text="{Binding AudioInfo}" FontSize="12" Foreground="{StaticResource BrushTextSecondary}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Center: Loop Workspace -->
        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Start Point -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <Border Background="{StaticResource BrushSurfaceDark}" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="{Binding [LoopStartLabel], Source={StaticResource Loc}}" HorizontalAlignment="Center" Foreground="{StaticResource BrushAccent}" Margin="0,0,0,15" FontWeight="Bold"/>
                            <TextBox Text="{Binding LoopStartSample, UpdateSourceTrigger=PropertyChanged}" 
                                     TextAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrushAccent}" 
                                     BorderBrush="{StaticResource BrushAccent}" BorderThickness="0,0,0,2" Margin="0,0,0,5"
                                     Background="Transparent" CaretBrush="{StaticResource BrushAccent}"/>
                            <TextBox Text="{Binding LoopStartSec, UpdateSourceTrigger=PropertyChanged}" 
                                     TextAlignment="Center" FontSize="14" Foreground="{StaticResource BrushTextPrimary}"
                                     Opacity="0.7" Background="Transparent" BorderThickness="0,0,0,1" 
                                     BorderBrush="{StaticResource BrushAccent}" Margin="30,5,30,0"
                                     CaretBrush="{StaticResource BrushTextPrimary}"/>

                            <UniformGrid Columns="2" Margin="0,20,0,0">
                                <Button Content="{Binding [BtnMin], Source={StaticResource Loc}, TargetNullValue='Min'}" Command="{Binding AdjustCommand}" CommandParameter="Start:Min" Style="{StaticResource SecondaryButton}" Margin="3"/>
                                <Button Content="{Binding [BtnMax], Source={StaticResource Loc}, TargetNullValue='Max'}" Command="{Binding AdjustCommand}" CommandParameter="Start:Max" Style="{StaticResource SecondaryButton}" Margin="3"/>
                            </UniformGrid>

                            <UniformGrid Columns="4" Margin="0,5,0,0">
                                <Button Content="-5s" Command="{Binding AdjustCommand}" CommandParameter="Start:-5" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>
                                <Button Content="-1s" Command="{Binding AdjustCommand}" CommandParameter="Start:-1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>
                                <Button Content="+1s" Command="{Binding AdjustCommand}" CommandParameter="Start:1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>
                                <Button Content="+5s" Command="{Binding AdjustCommand}" CommandParameter="Start:5" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>

                                <Button Content="-0.1s" Command="{Binding AdjustCommand}" CommandParameter="Start:-0.1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                                <Button Content="-0.01s" Command="{Binding AdjustCommand}" CommandParameter="Start:-0.01" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                                <Button Content="+0.01s" Command="{Binding AdjustCommand}" CommandParameter="Start:0.01" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                                <Button Content="+0.1s" Command="{Binding AdjustCommand}" CommandParameter="Start:0.1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- End Point -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Border Background="{StaticResource BrushSurfaceDark}" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="{Binding [LoopEndLabel], Source={StaticResource Loc}}" HorizontalAlignment="Center" Foreground="{StaticResource BrushDanger}" Margin="0,0,0,15" FontWeight="Bold"/>
                            <TextBox Text="{Binding LoopEndSample, UpdateSourceTrigger=PropertyChanged}" 
                                     TextAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrushDanger}" 
                                     BorderBrush="{StaticResource BrushDanger}" BorderThickness="0,0,0,2" Margin="0,0,0,5"
                                     Background="Transparent" CaretBrush="{StaticResource BrushDanger}"/>
                            <TextBox Text="{Binding LoopEndSec, UpdateSourceTrigger=PropertyChanged}" 
                                     TextAlignment="Center" FontSize="14" Foreground="{StaticResource BrushTextPrimary}"
                                     Opacity="0.7" Background="Transparent" BorderThickness="0,0,0,1" 
                                     BorderBrush="{StaticResource BrushDanger}" Margin="30,5,30,0"
                                     CaretBrush="{StaticResource BrushTextPrimary}"/>

                            <UniformGrid Columns="2" Margin="0,20,0,0">
                                <Button Content="{Binding [BtnMin], Source={StaticResource Loc}, TargetNullValue='Min'}" Command="{Binding AdjustCommand}" CommandParameter="End:Min" Style="{StaticResource SecondaryButton}" Margin="3"/>
                                <Button Content="{Binding [BtnMax], Source={StaticResource Loc}, TargetNullValue='Max'}" Command="{Binding AdjustCommand}" CommandParameter="End:Max" Style="{StaticResource SecondaryButton}" Margin="3"/>
                            </UniformGrid>

                            <UniformGrid Columns="4" Margin="0,5,0,0">
                                <Button Content="-5s" Command="{Binding AdjustCommand}" CommandParameter="End:-5" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>
                                <Button Content="-1s" Command="{Binding AdjustCommand}" CommandParameter="End:-1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>
                                <Button Content="+1s" Command="{Binding AdjustCommand}" CommandParameter="End:1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>
                                <Button Content="+5s" Command="{Binding AdjustCommand}" CommandParameter="End:5" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="11"/>

                                <Button Content="-0.1s" Command="{Binding AdjustCommand}" CommandParameter="End:-0.1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                                <Button Content="-0.01s" Command="{Binding AdjustCommand}" CommandParameter="End:-0.01" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                                <Button Content="+0.01s" Command="{Binding AdjustCommand}" CommandParameter="End:0.01" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                                <Button Content="+0.1s" Command="{Binding AdjustCommand}" CommandParameter="End:0.1" Style="{StaticResource SecondaryButton}" Margin="2" FontSize="10"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <!-- Row 1: Match controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Content="{Binding [MatchStart], Source={StaticResource Loc}}" Command="{Binding SmartMatchReverseCommand}" Width="110" Height="42"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Background="{StaticResource BrushSky}" Foreground="{StaticResource BrushTitleBar}"
                                ToolTip="{Binding [MatchStartToolTip], Source={StaticResource Loc}}"/>
                        <Button Content="{Binding [MatchEnd], Source={StaticResource Loc}}" Command="{Binding SmartMatchForwardCommand}" Width="110" Height="42"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,0,0" Background="{StaticResource BrushTeal}" Foreground="{StaticResource BrushTitleBar}"
                                ToolTip="{Binding [MatchEndToolTip], Source={StaticResource Loc}}"/>
                    </StackPanel>

                    <!-- Row 2: Action controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{Binding [ResetAB], Source={StaticResource Loc}}" Command="{Binding ResetABCommand}" Width="100" Height="42"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Background="{StaticResource BrushPink}" Foreground="{StaticResource BrushTitleBar}"
                                IsEnabled="{Binding IsABMode}"
                                ToolTip="{Binding [ResetABToolTip], Source={StaticResource Loc}}"/>
                        <Button Content="{Binding [PyRanking], Source={StaticResource Loc}}" Command="{Binding PyRankingCommand}" Width="100" Height="42"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Background="{StaticResource BrushRosewater}" Foreground="{StaticResource BrushTitleBar}"
                                ToolTip="{Binding [PyRankingToolTip], Source={StaticResource Loc}}"/>
                        <Button Content="{Binding [ApplyAndTest], Source={StaticResource Loc}}" Command="{Binding ApplyLoopCommand}" Width="130" Height="42"
                                Style="{StaticResource PrimaryButton}" FontWeight="Bold" Background="{StaticResource BrushAccent}"/>
                    </StackPanel>
                </StackPanel>

                <Grid Width="400" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding MatchWindowTitle}" FontSize="11" Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBlock Text="{Binding MatchWindowSize, StringFormat={}{0:F1}}" FontSize="15" Foreground="{StaticResource BrushAccent}" FontWeight="Bold" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Slider Style="{StaticResource ModernSlider}" Minimum="0.1" Maximum="10" Value="{Binding MatchWindowSize}" TickFrequency="0.1" IsSnapToTickEnabled="True" Height="30"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SearchRadiusTitle}" FontSize="11" Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBlock Text="{Binding SearchRadius, StringFormat={}{0:F0}}" FontSize="15" Foreground="{StaticResource BrushTeal}" FontWeight="Bold" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Slider Style="{StaticResource ModernSlider}" Minimum="1" Maximum="20" Value="{Binding SearchRadius}" TickFrequency="1" IsSnapToTickEnabled="True" Height="30"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
