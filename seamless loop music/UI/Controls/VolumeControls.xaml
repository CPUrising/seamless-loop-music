<UserControl x:Class="seamless_loop_music.UI.Controls.VolumeControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignWidth="150" d:DesignHeight="40"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <md:PackIcon Kind="VolumeHigh" Width="18" Height="18" 
                     Foreground="{StaticResource BrushTextPrimary}" Opacity="0.5"
                     VerticalAlignment="Center" Margin="0,0,8,0"/>
        <Slider Style="{StaticResource ModernSlider}"
                Width="{Binding SliderWidth, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=100}" 
                Minimum="0" Maximum="100" 
                Value="{Binding VolumeValue}" 
                IsMoveToPointEnabled="True"
                VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>
