<UserControl x:Class="seamless_loop_music.UI.Controls.PlaybackControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:seamless_loop_music.UI.Converters"
             d:DesignWidth="200" d:DesignHeight="60"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:PlayPauseIconConverter x:Key="PlayPauseIconConverter" />
    </UserControl.Resources>
    
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Button Command="{Binding PrevCommand}" Style="{StaticResource GhostIconButton}" Margin="5">
             <md:PackIcon Kind="SkipPrevious" Width="{Binding ButtonSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=24}" 
                          Height="{Binding ButtonSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=24}"/>
        </Button>
        
        <Button Command="{Binding PlayCommand}" 
                Style="{StaticResource PrimaryButton}" 
                Width="{Binding PlayButtonWidth, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=80}" 
                Height="{Binding PlayButtonHeight, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=40}" 
                Margin="10,0">
            <md:PackIcon Kind="{Binding IsPlaying, Converter={StaticResource PlayPauseIconConverter}}" 
                         Width="28" Height="28"/>
        </Button>

        <Button Command="{Binding NextCommand}" Style="{StaticResource GhostIconButton}" Margin="5">
            <md:PackIcon Kind="SkipNext" Width="{Binding ButtonSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=24}" 
                         Height="{Binding ButtonSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=24}"/>
        </Button>
    </StackPanel>
</UserControl>
