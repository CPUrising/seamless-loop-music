<UserControl x:Class="seamless_loop_music.UI.Controls.ProgressControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:seamless_loop_music.UI.Converters"
             d:DesignWidth="400" d:DesignHeight="50"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ProgressMarkerPositionConverter x:Key="ProgressMarkerPositionConverter"/>
    </UserControl.Resources>
    <StackPanel>
        <Grid>
            <TextBlock x:Name="TimeText" Text="{Binding TimeDisplay}" 
                       HorizontalAlignment="Right" FontSize="12" Opacity="0.6"
                       Foreground="{StaticResource BrushTextPrimary}"/>
        </Grid>
        <Grid x:Name="ProgressHost" Margin="0,2,0,0">
            <Slider x:Name="ProgressBar" Style="{StaticResource ModernSlider}"
                    Value="{Binding ProgressValue, Mode=TwoWay}" Maximum="1000"
                    IsMoveToPointEnabled="True"
                    Thumb.DragStarted="ProgressBar_DragStarted"
                    Thumb.DragCompleted="ProgressBar_DragCompleted"/>

            <Canvas IsHitTestVisible="False" ClipToBounds="True">
                <Border Width="2" Height="18" Canvas.Top="1" CornerRadius="1"
                        Background="{StaticResource BrushWarning}"
                        Visibility="{Binding HasLoopStartMarker, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.RenderTransform>
                        <TranslateTransform>
                            <TranslateTransform.X>
                                <MultiBinding Converter="{StaticResource ProgressMarkerPositionConverter}">
                                    <Binding ElementName="ProgressHost" Path="ActualWidth"/>
                                    <Binding Path="LoopStartMarkerLeft"/>
                                </MultiBinding>
                            </TranslateTransform.X>
                        </TranslateTransform>
                    </Border.RenderTransform>
                </Border>

                <Border Width="2" Height="18" Canvas.Top="1" CornerRadius="1"
                        Background="{StaticResource BrushWarning}"
                        Visibility="{Binding HasLoopEndMarker, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.RenderTransform>
                        <TranslateTransform>
                            <TranslateTransform.X>
                                <MultiBinding Converter="{StaticResource ProgressMarkerPositionConverter}">
                                    <Binding ElementName="ProgressHost" Path="ActualWidth"/>
                                    <Binding Path="LoopEndMarkerLeft"/>
                                </MultiBinding>
                            </TranslateTransform.X>
                        </TranslateTransform>
                    </Border.RenderTransform>
                </Border>
            </Canvas>
        </Grid>
    </StackPanel>
</UserControl>
