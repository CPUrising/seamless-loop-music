<UserControl x:Class="seamless_loop_music.UI.Controls.ProgressControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignWidth="400" d:DesignHeight="50"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Grid>
            <TextBlock x:Name="TimeText" Text="{Binding TimeDisplay}" 
                       HorizontalAlignment="Right" FontSize="12" Opacity="0.6"
                       Foreground="{StaticResource BrushTextPrimary}"/>
        </Grid>
        <Slider x:Name="ProgressBar" Style="{StaticResource ModernSlider}"
                Value="{Binding ProgressValue}" Maximum="1000" 
                IsMoveToPointEnabled="True" Margin="0,2,0,0"
                ValueChanged="ProgressBar_ValueChanged"/>
    </StackPanel>
</UserControl>
