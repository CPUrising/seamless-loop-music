<UserControl x:Class="seamless_loop_music.UI.Controls.TrackInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignWidth="300" d:DesignHeight="80"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Album Art -->
        <Border x:Name="ArtBorder" Width="{Binding ArtSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=48}" 
                Height="{Binding ArtSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=48}" 
                CornerRadius="6" Background="{StaticResource BrushSurface}" Margin="0,0,12,0">
            <Grid>
                <md:PackIcon Kind="Music" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                <Image Source="{Binding CoverImage, RelativeSource={RelativeSource AncestorType=UserControl}}" Stretch="UniformToFill">
                    <Image.Clip>
                        <RectangleGeometry Rect="0,0,100,100" RadiusX="6" RadiusY="6"/>
                    </Image.Clip>
                </Image>
            </Grid>
        </Border>

        <!-- Info -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding CurrentTrack.Title, FallbackValue='Not Playing'}" 
                       FontSize="{Binding TitleFontSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=14}" 
                       FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" 
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding CurrentTrack.Artist, FallbackValue='Unknown Artist'}" 
                       FontSize="{Binding SubtitleFontSize, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=12}" 
                       Foreground="{StaticResource BrushTextPrimary}" Opacity="0.7"
                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="AlbumText" Text="{Binding CurrentTrack.Album}" 
                       FontSize="11" Foreground="{StaticResource BrushTextPrimary}" Opacity="0.5"
                       Visibility="{Binding ShowAlbum, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
        
        <!-- Click Overlay if needed -->
        <Button Grid.ColumnSpan="2" Background="Transparent" BorderThickness="0" 
                Command="{Binding OpenDetailCommand}" 
                Visibility="{Binding IsClickable, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                Cursor="Hand"/>
    </Grid>
</UserControl>
