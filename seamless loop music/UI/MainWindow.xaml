<Window x:Class="seamless_loop_music.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:seamless_loop_music.UI.Views"
        xmlns:prism="http://prismlibrary.com/"
        Title="{Binding [AppTitle], Source={StaticResource Loc}}" Height="800" Width="1200"
        Icon="/Resources/app_icon.png"
        Background="{StaticResource BrushBackground}" Foreground="{StaticResource BrushTextPrimary}" FontFamily="Microsoft YaHei"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Style for Maximize/Restore button to switch icons based on WindowState -->
        <Style x:Key="MaximizeButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Content" Value="{StaticResource PathMaximize}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                    <Setter Property="Content" Value="{StaticResource PathRestore}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="MainTaskbarItemInfo">
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo x:Name="ThumbPrev"
                                 Description="Previous"
                                 ImageSource="{StaticResource DrawingIconPrev}"/>
                <ThumbButtonInfo x:Name="ThumbPlayPause"
                                 Description="Play/Pause"
                                 ImageSource="{StaticResource DrawingIconPlay}"/>
                <ThumbButtonInfo x:Name="ThumbNext"
                                 Description="Next"
                                 ImageSource="{StaticResource DrawingIconNext}"/>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Bar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="Auto"/> <!-- Bottom Bar -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Height="40" Background="{StaticResource BrushSurfaceDark}">
            <!-- Left Side: Icon and Title -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0">
                <Image Source="/Resources/app_icon.png" Width="18" Height="18" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding [AppTitle], Source={StaticResource Loc}}" 
                           Foreground="{StaticResource BrushTextSecondary}" 
                           FontSize="13" 
                           VerticalAlignment="Center"
                           FontWeight="Medium"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Settings Button (Now in Title Bar) -->
                <Button Click="BtnSettings_Click" 
                        Style="{StaticResource TitleBarButtonStyle}" 
                        Content="{StaticResource PathSettings}"
                        ToolTip="{Binding [Settings], Source={StaticResource Loc}}"/>
                
                <!-- System Controls -->
                <Button Click="BtnMinimize_Click" 
                        Style="{StaticResource TitleBarButtonStyle}" 
                        Content="{StaticResource PathMinimize}"/>
                
                <Button Click="BtnMaximize_Click" 
                        Style="{StaticResource MaximizeButtonStyle}"/>
                
                <Button Click="BtnClose_Click" 
                        Style="{StaticResource TitleBarCloseButtonStyle}" 
                        Content="{StaticResource PathClose}"/>
            </StackPanel>
        </Grid>
        
        <Grid Grid.Row="1">
            <!-- Main Content Region -->
            <Border>
                <ContentControl prism:RegionManager.RegionName="MainContentRegion" />
            </Border>
        </Grid>

        <!-- Bottom Bar: Playback Controls (Always visible) -->
        <Border Grid.Row="2" Background="{StaticResource BrushTitleBar}" Padding="15,10" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushBorder}">
            <views:PlaybackControlBar />
        </Border>
    </Grid>
</Window>
